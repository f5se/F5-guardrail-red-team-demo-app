# Calypso / F5 Guardrail
CALYPSOAI_URL=https://www.us1.calypsoai.app/
CALYPSOAI_TOKEN=Your-calypsoai-token
# Project 模式下的项目 ID，例如 0199dc56-934d-707f-bfae-e8bacbf2111c
CALYPSOAI_PROJECT_ID=Your-calypsoai-project-id
# Enterprise KB Skill 开启时使用的第二套 Project（Chat/Agent Guardrail 路径）
# 该功能需admin账户在Settings界面开启Enable Dual Project Routing By Enterprise Skill开关
CALYPSOAI_TOKEN_SECOND_PROJECT=Your-calypsoai-token-second-project
CALYPSOAI_PROJECT_ID_SECOND=Your-calypsoai-project-id-second
# Calypso 中配置的 Provider 名称，例如 deepseek-real-charge（可被前端选择的默认值）
DEFAULT_PROVIDER=Your-calypsoai-provider
# 前端下拉可选 Provider 列表，逗号分隔，例如：jinglin-google-gemini-133540,deepseek-JingLin-real-charge
PROVIDER_OPTIONS=jinglin-google-gemini-133540,deepseek-JingLin-real-charge

# 多轮对话：滑动窗口轮数、最大字符数、会话轮次过期时间（秒）
SLIDING_WINDOW_MAX_TURNS=8
SLIDING_WINDOW_MAX_CHARS=8000
CONVERSATION_TTL_SECONDS=120

# 调试：设为 1 时打印 F5 Guardrail 请求打点，用于判断「请求未发出」vs「未收到响应」
# GUARDRAIL_DEBUG=1
# Guardrail 请求超时时间（秒），默认 5；建议 3~15 之间
GUARDRAIL_TIMEOUT_SECONDS=5

# Hugging Face：模型缓存目录（可选）
HF_HOME=Your-hugging-face-home-directory
# 仅用于 HF 模型下载的代理，不用于连接 CalypsoAI
HF_PROXY=http://127.0.0.1:8010
# HF 令牌，建议设置以加速下载、避免限流
HF_TOKEN=Your-hugging-face-token

# ---------- Chat 直连模式（AI Chatbot/Agent 复选框）----------
# 直连 LLM Provider 的 OpenAI-compatible base URL（示例）
LLM_PROVIDER_URL=https://api.example-llm.com/v1
# 直连模式使用的模型名（示例）
LLM_PROVIDER_MODEL=example-chat-model
# 直连模式使用的 API Key（示例，勿填真实密钥）
LLM_PROVIDER_KEY_Direct=sk-your-direct-provider-key
# 可选兼容别名（如你使用全大写命名）
# LLM_PROVIDER_KEY_DIRECT=sk-your-direct-provider-key

# ---------- OOB 模式（Guardrail Integration 视图旁路演示）----------
# 使用 OOB 时必填，请按实际部署填写（需与 docs/nginx 配置的监听地址一致）
OOB_PROXY_URL=http://localhost:8787
# 使用 OOB 时必填，发往 LLM 的 API Key（Bearer），按实际 LLM 提供商配置
LLM_PROVIDER_KEY=Your-llm-provider-api-key
# 不填时缺省为 deepseek-chat；使用 OOB 时建议按实际调用的模型名配置
OOB_MODEL=deepseek-chat
