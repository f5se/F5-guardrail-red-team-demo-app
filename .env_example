# Calypso / F5 Guardrail (main Chat, Agent, Inline Guardrail path)
CALYPSOAI_URL=https://www.us1.calypsoai.app/
CALYPSOAI_TOKEN=Your-calypsoai-token
# Project ID when using Project mode, e.g. 0199dc56-934d-707f-bfae-e8bacbf2111c
CALYPSOAI_PROJECT_ID=Your-calypsoai-project-id
# Second project/token pair for Enterprise KB Skill ON (Guardrail path). Requires admin Settings: Enable Dual Project Routing By Enterprise Skill.
CALYPSOAI_TOKEN_SECOND_PROJECT=Your-calypsoai-token-second-project
CALYPSOAI_PROJECT_ID_SECOND=Your-calypsoai-project-id-second
# Provider name registered in Calypso; server default when Settings “LLM Provider” is empty
DEFAULT_PROVIDER=Your-calypsoai-provider
# Comma-separated provider IDs for Settings dropdown, e.g. jinglin-google-gemini-133540,deepseek-JingLin-real-charge
PROVIDER_OPTIONS=jinglin-google-gemini-133540,deepseek-JingLin-real-charge

# Multi-turn sliding window and session window size
SLIDING_WINDOW_MAX_TURNS=8
SLIDING_WINDOW_MAX_CHARS=8000
CONVERSATION_TTL_SECONDS=120

# GUARDRAIL_DEBUG=1  # logs Guardrail checkpoints to the terminal when set to 1/true/yes
GUARDRAIL_TIMEOUT_SECONDS=5

# Hugging Face (local ML engines)
HF_HOME=Your-hugging-face-home-directory
HF_PROXY=http://127.0.0.1:8010
HF_TOKEN=Your-hugging-face-token

# ---------- Direct LLM mode (checkbox in AI Chatbot / Agent) ----------
LLM_PROVIDER_URL=https://api.example-llm.com/v1
LLM_PROVIDER_MODEL=example-chat-model
LLM_PROVIDER_KEY_Direct=sk-your-direct-provider-key
# LLM_PROVIDER_KEY_DIRECT=sk-your-direct-provider-key

# ---------- OOB mode (Guardrail Integration bypass demo) ----------
OOB_PROXY_URL=http://localhost:8787
LLM_PROVIDER_KEY=Your-llm-provider-api-key
OOB_MODEL=deepseek-chat

# ---------- Agentic Security (OpenAI-compatible) ----------
AGENTIC_BASE_URL=
AGENTIC_TOKEN=Your-agentic-token
AGENTIC_MODEL=deepseek-chat

# ---------- Dataset Test (optional PoC overrides; NOT used by main Chat/Agent) ----------
# Main app uses CALYPSOAI_* + DEFAULT_PROVIDER only.
# Dataset uses Guardrail_PoC_* below when wizard fields are empty; otherwise falls back to CALYPSOAI_PROJECT_ID / DEFAULT_PROVIDER / CALYPSOAI_TOKEN / CALYPSOAI_URL.
# Guardrail_PoC_Token=
# Guardrail_PoC_Project=
# Guardrail_PoC_Provider=
# Guardrail_PoC_Calypso_URL=
# Per-row Guardrail timeout defaults to GUARDRAIL_TIMEOUT_SECONDS. Max concurrent dataset jobs: admin Settings → dataset_max_running_tasks (settings.json), not here.
